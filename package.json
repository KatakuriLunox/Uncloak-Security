  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "ora": "^5.4.1",
    "table": "^6.8.2"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.11.0",
    "@types/table": "^6.3.2",
    "typescript": "^5.3.3"
  }
}
