{
  "name": "uncloak",
  "version": "1.0.0",
  "description": "Security auditing CLI tool for developers - finds vulnerabilities, code issues, backdoors, and malicious activity",
  "main": "dist/index.js",
  "bin": {
    "uncloak": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "security",
